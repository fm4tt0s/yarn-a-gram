// config.js
module.exports = {
  apiId: YOUR_API_ID,
  apiHash: "YOUR_API_HASH",
  stringSession: "SESSION_STRING_IF_AVAILABLE", // this will be generated by running the script first time, then copy/paste here to avoid re-authenticating every time
  useWSS: false, // set to true if you want to use WebSocket connection (may be more stable in some environments, but can cause issues in others - test both options to see which works better for you - usually not required)

  channelsToWatch: ["channel_name_1", "channel_name_2"], // Telegram channel usernames to monitor (without @) - the 'username' after t.me/ - e.g. "t.me/news_channel" = "news_channel"
  keywords: ["keyword_1", "keyword_2"], // keywords to look for in messages (case-insensitive)

  pollIntervalMs: 90000, // how often to check for new messages in milliseconds (10000 = 10 seconds) - you can set this to a lower value for more real-time monitoring, but be mindful of Telegram's rate limits. 90000ms = 1.5 minutes is a good balance for most use cases.

  apiUrl: null, // optional, set to null to disable

  // you can use _keyword_ and _channel_ placeholders in the command, which will be replaced with the actual matched keywords and channel name

  onKeywordCommand: null, // optional shell command to run when a keyword is found
  // some practical examples on this:
  // play a sound on macOS
  // onKeywordCommand: "afplay /System/Library/Sounds/Ping.aiff"
  // desktop notification on Linux
  // onKeywordCommand: "notify-send '🔔 Keyword found on Telegram!'"
  // desktop notification on macOS
  // onKeywordCommand: `osascript -e 'display notification "Keyword found!" with title "Yarn-A-Gram"'`
  // macOS terminal-notifier (more customizable notifications)
  // onKeywordCommand: `terminal-notifier -title "Yarn-A-Gram" -message "Keyword found!" -sound default`
  // run a custom script
  // onKeywordCommand: "bash /path/to/your/script.sh"
  // EXTRA
  // you can also include the matched keywords in the command by using a placeholder like _keyword_, which will be replaced with the actual keywords found in the message. For example:
  // onKeywordCommand: `terminal-notifier -title "Yarn-A-Gram" -message "Keywords found: _keyword_" -sound default`
};